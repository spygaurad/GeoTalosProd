import os

# Root directory of your Python project
PROJECT_DIR = "."

# Output file
OUTPUT_FILE = "combined_codebase.py"

# Patterns to ignore
IGNORE_DIRS = {"__pycache__", ".git", ".venv", "venv", "env", "tests", "test"}
IGNORE_FILES_PREFIX = ("test_",)
IGNORE_FILES_SUFFIX = ("_test.py",)

def should_skip(file_path):
    filename = os.path.basename(file_path)

    if filename.startswith(IGNORE_FILES_PREFIX):
        return True

    if filename.endswith(IGNORE_FILES_SUFFIX):
        return True

    return False


with open(OUTPUT_FILE, "w", encoding="utf-8") as outfile:
    for root, dirs, files in os.walk(PROJECT_DIR):

        # Remove ignored directories
        dirs[:] = [d for d in dirs if d not in IGNORE_DIRS]

        for file in sorted(files):
            if file.endswith(".py"):
                file_path = os.path.join(root, file)

                if should_skip(file_path):
                    continue

                if file == OUTPUT_FILE:
                    continue

                outfile.write(f"\n\n# ===== File: {file_path} =====\n\n")

                with open(file_path, "r", encoding="utf-8") as infile:
                    outfile.write(infile.read())

print(f"Codebase combined into {OUTPUT_FILE}")
